  <div class="card-row">{status_chip(status)}<span class="time">{t}</span></div>
  <p class="prompt">{prompt}</p>
  <div class="jobmeta"><a href="/job/{rid}?token={TOKEN}">View job</a> · <code>{rid}</code></div>
  {err}
</div>
</article>'''


