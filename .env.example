# Load real values from ~/.hivemindos/.env with: hive-env-run -- <command>

# Durable state, scoped imports, and operator boundaries
CONTENT_STUDIO_DATA_DIR=
CONTENT_STUDIO_RUNS_DIR=
CONTENT_STUDIO_IMPORT_ROOTS=
CONTENT_STUDIO_APPROVAL_SIGNING_SECRET=
CONTENT_STUDIO_OPERATOR_TOKEN=
CONTENT_STUDIO_CONTROL_TOKEN=
CONTENT_STUDIO_CONTROL_HOST=127.0.0.1
CONTENT_STUDIO_CONTROL_PORT=8765
CONTENT_STUDIO_MAX_GENERATION_BYTES=524288000
CONTENT_STUDIO_ALLOW_PRIVATE_GENERATION_DOWNLOADS=false

# Operator-registered agent runtimes. The suffix becomes the runtime id.
# Example: CONTENT_STUDIO_RUNTIME_HERMES_COMMAND=hermes run --stdin
CONTENT_STUDIO_RUNTIME_EXAMPLE_COMMAND=

# Local creative services
PALMIER_MCP_URL=http://127.0.0.1:19789/mcp
UNIVERSAL_TTS_URL=http://127.0.0.1:8799
ACE_STEP_API_BASE_URL=

# Optional portable overrides. By default these are discovered from
# ~/.hivemindos/app-preferences.json and the shared env.
MEDIA_STUDIO_MCP_URL=
MEDIA_STUDIO_UPLOAD_BASE=
MEDIA_STUDIO_AUTH_ENV_KEY=MEDIA_STUDIO_TOKEN
MEDIA_STUDIO_TOKEN=
MEDIA_STUDIO_WORKFLOW_ID=

# Stock and cloud generation
# HivemindOS-hosted generation uses the shared HivemindOS credit pool and
# never exposes the upstream provider key to this process.
HIVEMINDOS_URL=http://127.0.0.1:5020
# Optional path to the HivemindOS checkout's .env.local. The default discovery
# also checks HIVEMINDOS_PROJECT_ROOT, a sibling hivemind-os checkout, and the
# machine-local ~/.hivemindos/.env without copying the token.
HIVEMINDOS_ENV_FILE=
HIVEMINDOS_DASHBOARD_DEVICE_TOKEN=
HIVEMINDOS_CONTENT_STUDIO_AGENT_ID=content-studio
PEXELS_API_KEY=
PIXABAY_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
MUAPI_API_KEY=
HIGGSFIELD_API_KEY_ID=
HIGGSFIELD_API_KEY_SECRET=
ELEVENLABS_API_KEY=

# Postiz (self-hosted or cloud)
POSTIZ_URL=http://127.0.0.1:4007/api
POSTIZ_API_KEY=
POSTIZ_INTEGRATION_YOUTUBE=
POSTIZ_INTEGRATION_TIKTOK=
POSTIZ_INTEGRATION_INSTAGRAM=
POSTIZ_INTEGRATION_X=

# Upload-Post
UPLOAD_POST_API_URL=https://api.upload-post.com/api/upload
UPLOAD_POST_API_KEY=
UPLOAD_POST_USERNAME=

# Live publishing stays disabled unless explicitly enabled for an approved run.
CONTENT_STUDIO_ENABLE_LIVE_PUBLISH=false
